&"hit1": {"loop": false, "segments": [{"cycles": 1, "holds": PackedInt32Array(2, 2, 6), "row": 6, "start_column": 0}]},
&"hit2": {"loop": false, "segments": [{"cycles": 1, "holds": PackedInt32Array(2, 2, 6), "row": 7, "start_column": 0}]},
&"hit3": {"loop": false, "segments": [{"cycles": 1, "holds": PackedInt32Array(2, 2, 2, 10), "row": 8, "start_column": 0}]},
