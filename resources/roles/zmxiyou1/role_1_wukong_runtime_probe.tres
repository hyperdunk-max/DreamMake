[gd_resource type="Resource" script_class="RoleAnimationProfile" load_steps=2 format=3]

[ext_resource type="Script" path="res://src/animation/role_animation_profile.gd" id="1_profile"]

[resource]
script = ExtResource("1_profile")
role_id = 1
role_key = &"zmxiyou1_wukong_probe"
display_name = "造1悟空（换装验证）"
logical_fps = 24.0
frame_size = Vector2i(200, 200)
source_facing = -1
visual_offset = Vector2(0, -92)
weapon_z_index = -1
default_action = &"idle"
default_body_showid = 1
default_weapon_showid = 1
body_atlas_paths = {1: "res://assets/selected/zmxiyou1/wukong/runtime_probe/body_candidates/showid_1/source_atlas.png", 2: "res://assets/selected/zmxiyou1/wukong/runtime_probe/body_candidates/showid_2/source_atlas.png"}
body_names = {1: "默认防具"}
weapon_atlas_paths = {1: "res://assets/selected/zmxiyou1/wukong/runtime_probe/weapon_candidates/showid_1/source_atlas.png", 2: "res://assets/selected/zmxiyou1/wukong/runtime_probe/weapon_candidates/showid_2/source_atlas.png"}
weapon_names = {1: "默认行者棍", 2: "普通行者棍"}
actions = {
&"hit1": {"loop": false, "segments": [{"cycles": 1, "holds": PackedInt32Array(10), "row": 3, "start_column": 0}]},
&"hurt": {"loop": false, "segments": [{"cycles": 1, "holds": PackedInt32Array(8), "row": 7, "start_column": 0}]},
&"idle": {"loop": true, "segments": [{"cycles": 1, "holds": PackedInt32Array(6), "row": 0, "start_column": 0}]},
&"jump_double": {"loop": false, "segments": [{"cycles": 1, "holds": PackedInt32Array(6), "row": 5, "start_column": 0}]},
&"jump_fall": {"loop": false, "segments": [{"cycles": 1, "holds": PackedInt32Array(1), "row": 6, "start_column": 0}]},
&"jump_up": {"loop": false, "segments": [{"cycles": 1, "holds": PackedInt32Array(1), "row": 4, "start_column": 0}]},
&"run": {"loop": true, "segments": [{"cycles": 1, "holds": PackedInt32Array(2), "row": 2, "start_column": 0}]},
&"walk": {"loop": true, "segments": [{"cycles": 1, "holds": PackedInt32Array(4), "row": 1, "start_column": 0}]}
}
